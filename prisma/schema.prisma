generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AGENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  INSPECTION_SCHEDULED
  CLOSED
  LOST
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  PENDING
}

enum AppointmentStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
}

model User {
  id           String        @id @default(cuid())
  fullName     String
  email        String        @unique
  password     String
  role         Role
  properties   Property[]
  leads        Lead[]
  appointments Appointment[]
  notes        Note[]
  createdAt    DateTime      @default(now())
}

model Property {
  id              String         @id @default(cuid())
  title           String
  location        String
  price           Float
  description     String
  status          PropertyStatus @default(AVAILABLE)
  imageUrl        String?
  assignedAgentId String?
  assignedAgent   User?          @relation(fields: [assignedAgentId], references: [id])
  leads           Lead[]
  createdAt       DateTime       @default(now())
}

model Lead {
  id               String        @id @default(cuid())
  fullName         String
  email            String?
  phone            String
  budget           Float?
  interestLocation String?
  status           LeadStatus    @default(NEW)
  source           String?
  assignedAgentId  String?
  assignedAgent    User?         @relation(fields: [assignedAgentId], references: [id])
  propertyId       String?
  property         Property?     @relation(fields: [propertyId], references: [id])
  appointments     Appointment[]
  payments         Payment[]
  notes            Note[]
  createdAt        DateTime      @default(now())
}

model Appointment {
  id              String            @id @default(cuid())
  leadId          String
  agentId         String
  appointmentDate DateTime
  status          AppointmentStatus @default(UPCOMING)
  lead            Lead              @relation(fields: [leadId], references: [id])
  agent           User              @relation(fields: [agentId], references: [id])
  createdAt       DateTime          @default(now())
}

model Payment {
  id            String        @id @default(cuid())
  leadId        String
  amount        Float
  paymentStatus PaymentStatus @default(PENDING)
  paymentDate   DateTime
  note          String?
  lead          Lead          @relation(fields: [leadId], references: [id])
  createdAt     DateTime      @default(now())
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  agentId   String
  content   String
  lead      Lead     @relation(fields: [leadId], references: [id])
  agent     User     @relation(fields: [agentId], references: [id])
  createdAt DateTime @default(now())
}
